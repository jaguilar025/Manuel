{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Manuel",
  "version": "0.1.0",
  "identifier": "dev.jorge.manuel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Manuel",
        "width": 1000,
        "height": 640,
        "minWidth": 760,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Input mapper",
    "longDescription": "Lightweight HID and keyboard input mapper.",
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1", "libwebkit2gtk-4.1-0"]
      }
    }
  }
}
